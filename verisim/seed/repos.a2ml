# SPDX-License-Identifier: MPL-2.0
# Master repo registry — all hyperpolymath repositories with clade assignments
# Primary key: GitHub. Foreign keys: GitLab, Bitbucket, Codeberg, SourceHut.
#
# Each entry: [repo.{name}] with primary clade, secondary clades, lineage type,
# and monorepo parent (if applicable).
#
# Lineage types: standalone, monorepo, monorepo-child, inflated, deflated

[meta]
version = "1.0.0"
created = "2026-03-16"
author = "Jonathan D.A. Jewell <j.d.a.jewell@open.ac.uk>"
total-repos = 200
format = "repo-registry"

