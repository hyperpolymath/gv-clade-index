# VeriSimDB configuration for the clade-index registry

[verisimdb]
instance-name = "clade-registry"
version = "1.0.0"
mode = "standalone"

[verisimdb.api]
http-port = 8080
grpc-port = 50051
bind-address = "0.0.0.0"

[verisimdb.sync]
interval = "1h"
sources = ["git-metadata", "state-a2ml", "bot-findings"]
export-target = "cloudflare-kv"

[verisimdb.drift]
enabled = true
check-interval = "1h"
threshold-staleness = 0.3
threshold-hash-mismatch = 0.0

[verisimdb.auth]
public-read = true
api-key-required-for = ["llm", "bot-write"]
oauth-provider = "github"
admin-handles = ["hyperpolymath"]
